// ═══════════════════════════════════════════
// DATA PARSING
// ═══════════════════════════════════════════
function parseLong(data, paperCol, coderCol, cols) {
  const wide = {};
  data.forEach(row => {
    const pid = String(row[paperCol]);
    const cid = String(row[coderCol]);
    if (!wide[pid]) wide[pid] = {};
    if (!wide[pid][cid]) wide[pid][cid] = {};
    cols.forEach(c => { wide[pid][cid][c] = row[c]; });
  });
  return wide;
}

function parseWide(data, paperCol, cols) {
  const wide = {};
  data.forEach(row => {
    const pid = String(row[paperCol]);
    if (!wide[pid]) wide[pid] = {};
    cols.forEach(c => {
      if (!wide[pid][c]) wide[pid][c] = {};
      wide[pid][c][c] = row[c];
    });
  });
  return wide;
}

// ═══════════════════════════════════════════
// VALUE NORMALIZATION
// ═══════════════════════════════════════════

// Free-text fields excluded from IRR (exact-string matching is unreliable)
const FREETEXT_FIELDS = new Set([
  'research question',
  'tested llm model & version used',
  'tested model & techniques list',
  'baseline list',
]);

// Tokens treated as missing
const MISSING_TOKENS = new Set(['', 'n/a', 'na', 'none', '-', '--', 'n.a.', 'tbd', '?']);

function isFreeText(colName) {
  return FREETEXT_FIELDS.has(colName.trim().toLowerCase());
}

function isNumericCol(colName) {
  // Heuristic: column name contains "number", "total", "count", "min", "max",
  // or ends with a number-like suffix
  return /\b(number|total|count|min|max|baseline value|baseline difference)\b/i.test(colName);
}

function isMultiselect(colName) {
  return /list$/i.test(colName) && !isFreeText(colName);
}

function normalizeValue(raw, colName) {
  if (raw === null || raw === undefined) return null;
  let s = String(raw).trim();
  if (MISSING_TOKENS.has(s.toLowerCase())) return null;

  // Numeric normalization: parse and normalize so "85" == "85.0"
  if (isNumericCol(colName)) {
    const isPct = s.endsWith('%');
    const stripped = s.replace(/%$/, '').replace(/,/g, '').trim();
    const n = parseFloat(stripped);
    if (!isNaN(n)) {
      const val = isPct ? n / 100 : n;
      const rounded = Math.round(val * 10000) / 10000;
      return rounded === Math.floor(rounded) ? String(Math.floor(rounded)) : String(rounded);
    }
  }

  // Multiselect: sort order-independently
  if (isMultiselect(colName) && s.includes(',')) {
    const parts = s.split(',').map(p => p.trim().toLowerCase()).filter(Boolean).sort();
    return parts.length ? parts.join('|') : null;
  }

  return s.toLowerCase();
}

// ═══════════════════════════════════════════
// RECORDS — flat list of (paper, rq, field, coder, value)
// This is the canonical data structure for all IRR calculations
// ═══════════════════════════════════════════
function buildRecords(rawData, paperCol, coderCol, cols, allowedCoders) {
  const PAPER_ID_COL = 'Paper ID';
  const ARTIFACT_ROW = 'numerical (index identifier)';

  const records = []; // {paper, rq, field, coder, value}

  rawData.forEach(row => {
    const rqId = String(row[paperCol] ?? '').trim();
    if (!rqId || /^\d+$/.test(rqId)) return; // bare integer artifacts
    if (rqId.toLowerCase() === ARTIFACT_ROW) return;

    const coder = String(row[coderCol] ?? '').trim();
    if (!coder || EXCLUDED_CODERS.has(coder.toLowerCase())) return;
    if (allowedCoders && !allowedCoders.has(coder)) return;

    // Paper ID for grouping
    const paperId = row[PAPER_ID_COL] !== undefined
      ? String(row[PAPER_ID_COL]).trim() : rqId;

    cols.forEach(col => {
      const raw = row[col];
      const value = normalizeValue(raw, col);
      if (value === null) return; // skip missing
      records.push({ paper: paperId, rq: rqId, field: col, coder, value });
    });
  });

  return records;
}

// ═══════════════════════════════════════════
// IRR MATH — pooled coincidence matrix
// ═══════════════════════════════════════════
function avg(arr) { return arr.reduce((a,b) => a+b, 0)/arr.length; }

// Core pooled Krippendorff's alpha (nominal)
// records: [{paper, rq, field, coder, value}]
// filterFn: optional fn(record) => bool to restrict scope
function krippendorffAlphaPooled(records, filterFn) {
  // Group by (paper, rq, field) unit -> {coder -> value}
  const units = new Map();
  const filtered = filterFn ? records.filter(filterFn) : records;

  filtered.forEach(({paper, rq, field, coder, value}) => {
    const key = `${paper}\x00${rq}\x00${field}`;
    if (!units.has(key)) units.set(key, {});
    units.get(key)[coder] = value;
  });

  // Build coincidence matrix
  const coinc = new Map(); // "va\x00vb" -> count
  const mu = new Map();    // value -> marginal count

  units.forEach(coderMap => {
    const vals = Object.values(coderMap);
    const m = vals.length;
    if (m < 2) return;
    const cnt = new Map();
    vals.forEach(v => cnt.set(v, (cnt.get(v) || 0) + 1));
    cnt.forEach((ca, a) => {
      cnt.forEach((cb, b) => {
        const pairs = a === b ? ca * (ca - 1) : ca * cb;
        const w = pairs / (m - 1);
        const key = `${a}\x00${b}`;
        coinc.set(key, (coinc.get(key) || 0) + w);
        mu.set(a, (mu.get(a) || 0) + w);
      });
    });
  });

  const n = [...mu.values()].reduce((s, v) => s + v, 0);
  if (n < 2) return null;

  const vals = [...mu.keys()];
  // Observed disagreement
  let Do = 0;
  vals.forEach(a => vals.forEach(b => {
    if (a !== b) Do += (coinc.get(`${a}\x00${b}`) || 0);
  }));
  Do /= n;

  // Expected disagreement
  let De = 0;
  vals.forEach(a => vals.forEach(b => {
    if (a !== b) De += mu.get(a) * mu.get(b);
  }));
  De /= (n * (n - 1));

  if (De === 0) return 1;
  return 1 - Do / De;
}

// Pairwise % agreement from records
function pairwiseAgreementFromRecords(records, filterFn) {
  const filtered = filterFn ? records.filter(filterFn) : records;
  // Group by unit
  const units = new Map();
  filtered.forEach(({paper, rq, field, coder, value}) => {
    const key = `${paper}\x00${rq}\x00${field}`;
    if (!units.has(key)) units.set(key, {});
    units.get(key)[coder] = value;
  });

  const pairs = [];
  units.forEach(coderMap => {
    const entries = Object.entries(coderMap);
    for (let i = 0; i < entries.length; i++) {
      for (let j = i+1; j < entries.length; j++) {
        pairs.push(entries[i][1] === entries[j][1] ? 1 : 0);
      }
    }
  });
  return pairs.length ? avg(pairs) : null;
}

// Cohen's kappa from records (exactly 2 coders)
function cohensKappaFromRecords(records, filterFn, coders) {
  if (coders.length !== 2) return null;
  const [c1, c2] = coders;
  const filtered = filterFn ? records.filter(filterFn) : records;

  const units = new Map();
  filtered.forEach(({paper, rq, field, coder, value}) => {
    const key = `${paper}\x00${rq}\x00${field}`;
    if (!units.has(key)) units.set(key, {});
    units.get(key)[coder] = value;
  });

  const pairs = [];
  units.forEach(coderMap => {
    const a = coderMap[c1], b = coderMap[c2];
    if (a !== undefined && b !== undefined) pairs.push([a, b]);
  });
  if (!pairs.length) return null;

  const N = pairs.length;
  const cats = [...new Set(pairs.flat())];
  const po = pairs.filter(([a,b]) => a === b).length / N;
  let pe = 0;
  cats.forEach(c => {
    const pa = pairs.filter(([a]) => a === c).length / N;
    const pb = pairs.filter(([,b]) => b === c).length / N;
    pe += pa * pb;
  });
  return pe >= 1 ? 1 : (po - pe) / (1 - pe);
}

// Fleiss' kappa from records (3+ coders)
function fleissKappaFromRecords(records, filterFn) {
  const filtered = filterFn ? records.filter(filterFn) : records;
  const units = new Map();
  filtered.forEach(({paper, rq, field, coder, value}) => {
    const key = `${paper}\x00${rq}\x00${field}`;
    if (!units.has(key)) units.set(key, {});
    units.get(key)[coder] = value;
  });

  const unitArr = [...units.values()].filter(m => Object.keys(m).length >= 2);
  if (!unitArr.length) return null;

  const cats = [...new Set(unitArr.flatMap(m => Object.values(m)))];

  const nij = unitArr.map(m => {
    const counts = Object.fromEntries(cats.map(c => [c, 0]));
    Object.values(m).forEach(v => { if (counts[v] !== undefined) counts[v]++; });
    return counts;
  });
  const ni = nij.map(row => Object.values(row).reduce((a,b) => a+b, 0));
  const N = ni.reduce((a,b) => a+b, 0);
  if (!N) return null;

  const Pi = nij.map((row, i) => {
    const t = ni[i]; if (t <= 1) return 0;
    return cats.reduce((acc, c) => acc + row[c]*(row[c]-1), 0) / (t*(t-1));
  });
  const Pbar = avg(Pi);
  const Pj = cats.map(c => nij.reduce((acc, row) => acc + row[c], 0) / N);
  const Pe = Pj.reduce((acc, p) => acc + p*p, 0);
  return Pe >= 1 ? 1 : (Pbar - Pe) / (1 - Pe);
}

// Unified entry point — dispatches to the correct pooled function
function calcMetricFromRecords(metric, records, filterFn, coders) {
  if (metric === 'alpha')    return krippendorffAlphaPooled(records, filterFn);
  if (metric === 'pairwise') return pairwiseAgreementFromRecords(records, filterFn);
  if (metric === 'cohen')    return cohensKappaFromRecords(records, filterFn, coders);
  if (metric === 'fleiss')   return fleissKappaFromRecords(records, filterFn);
  return null;
}

// Keep old matrix-based helpers for legacy use in pairwise detail table
function pairwiseAgreement(matrix) {
  const n = matrix[0].length;
  const pairs = [];
  for (let i = 0; i < matrix.length; i++) {
    for (let j = i+1; j < matrix.length; j++) {
      let agree = 0, total = 0;
      for (let k = 0; k < n; k++) {
        const a = matrix[i][k], b = matrix[j][k];
        if (a !== null && b !== null) { total++; if (String(a) === String(b)) agree++; }
      }
      if (total > 0) pairs.push(agree/total);
    }
  }
  return pairs.length ? avg(pairs) : null;
}

function parseVal(v) { const n=Number(v); return isNaN(n)?String(v):n; }

function delta(vk,vl,dataType,allVals) {
  if (String(vk)===String(vl)) return 0;
  if (dataType==='nominal') return 1;
  if (dataType==='ordinal') {
    const ki=allVals.indexOf(vk),li=allVals.indexOf(vl);
    if (ki===-1||li===-1) return 1;
    return Math.pow(Math.abs(ki-li),2);
  }
  const nk=Number(vk),nl=Number(vl);
  return (isNaN(nk)||isNaN(nl)) ? 1 : Math.pow(nk-nl,2);
}

