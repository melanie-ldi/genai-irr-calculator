<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IRR Calculator — LDI</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Syne:wght@400;600;700;800&display=swap');

  :root {
    --bg: #0f1117;
    --surface: #171b26;
    --surface2: #1e2333;
    --surface3: #252b3d;
    --border: #2e354f;
    --border-bright: #3d4666;
    --accent: #6b8afd;
    --accent2: #a78bfa;
    --accent3: #34d399;
    --warn: #f59e0b;
    --error: #f87171;
    --text: #e2e8f0;
    --text-dim: #8892b0;
    --text-faint: #4a5578;
    --mono: 'DM Mono', monospace;
    --sans: 'Syne', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 32px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }
  .logo-mark {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; font-weight: 800; color: white;
    flex-shrink: 0;
  }
  header h1 { font-size: 17px; font-weight: 700; letter-spacing: -.3px; }
  header p  { font-size: 12px; color: var(--text-dim); font-family: var(--mono); }
  .header-right { margin-left: auto; display: flex; align-items: center; gap: 12px; }
  .app-body {
    display: grid;
    grid-template-columns: 340px 1fr;
    flex: 1;
    overflow: hidden;
    height: calc(100vh - 69px - 58px);
  }

  .sidebar {
    border-right: 1px solid var(--border);
    background: var(--surface);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .sidebar-section {
    padding: 18px 20px;
    border-bottom: 1px solid var(--border);
  }
  .section-label {
    font-size: 10px; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--text-faint); margin-bottom: 12px;
    font-family: var(--mono);
  }

  /* Drop zone */
  .drop-zone {
    border: 1.5px dashed var(--border-bright);
    border-radius: 10px; padding: 24px 16px;
    text-align: center; cursor: pointer;
    transition: all .2s; background: var(--surface2);
    position: relative;
  }
  .drop-zone:hover, .drop-zone.drag-over {
    border-color: var(--accent);
    background: rgba(107,138,253,.07);
  }
  .drop-zone input[type=file] {
    position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
  }
  .drop-icon { font-size: 26px; margin-bottom: 6px; }
  .drop-text { font-size: 12px; color: var(--text-dim); line-height: 1.5; }
  .drop-text strong { color: var(--accent); }
  .drop-formats { font-family: var(--mono); font-size: 10px; color: var(--text-faint); margin-top: 5px; }
  .file-loaded { background: rgba(52,211,153,.07); border-color: var(--accent3); border-style: solid; }

  /* Sheet version selector */
  .version-cards { display: flex; flex-direction: column; gap: 6px; }
  .version-card {
    padding: 10px 13px;
    border-radius: 8px;
    border: 1.5px solid var(--border);
    background: var(--surface2);
    cursor: pointer;
    transition: all .15s;
    display: flex; align-items: center; gap: 10px;
    user-select: none;
  }
  .version-card:hover { border-color: var(--border-bright); }
  .version-card.active { border-color: var(--accent); background: rgba(107,138,253,.08); }
  .version-card.disabled { opacity: .38; cursor: not-allowed; }
  .version-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--border-bright); flex-shrink: 0; transition: background .15s;
  }
  .version-card.active .version-dot { background: var(--accent); }
  .version-card.disabled .version-dot { background: var(--text-faint); }
  .version-name { font-size: 12px; font-weight: 600; }
  .version-sub { font-size: 10px; color: var(--text-faint); font-family: var(--mono); }
  .version-badge {
    margin-left: auto; font-family: var(--mono); font-size: 9px;
    padding: 2px 7px; border-radius: 100px;
    background: var(--surface3); color: var(--text-faint);
    border: 1px solid var(--border);
  }

  /* Detection banner */
  .detect-banner {
    margin-top: 10px; padding: 9px 12px;
    border-radius: 7px; font-family: var(--mono); font-size: 11px;
    display: none; gap: 8px; align-items: flex-start;
    background: rgba(107,138,253,.1); border: 1px solid #6b8afd33; color: var(--accent);
  }
  .detect-banner.visible { display: flex; }

  label.ctrl-label {
    display: block; font-size: 11px; color: var(--text-dim);
    margin-bottom: 6px; font-family: var(--mono);
  }
  select, input[type=text] {
    width: 100%; background: var(--surface3); border: 1px solid var(--border);
    border-radius: 6px; color: var(--text); font-family: var(--mono); font-size: 12px;
    padding: 8px 10px; outline: none; transition: border-color .15s;
    appearance: none; -webkit-appearance: none;
  }
  select:focus, input[type=text]:focus { border-color: var(--accent); }
  select option { background: var(--surface3); }
  .ctrl-row { margin-bottom: 12px; }

  /* Col picker */
  .col-picker-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 6px;
  }
  .col-picker-count {
    font-family: var(--mono); font-size: 10px; color: var(--accent);
  }
  .col-picker-actions { display: flex; gap: 6px; }
  .picker-action-btn {
    font-family: var(--mono); font-size: 10px; padding: 2px 8px;
    border-radius: 4px; border: 1px solid var(--border);
    background: transparent; color: var(--text-faint); cursor: pointer;
    transition: all .12s;
  }
  .picker-action-btn:hover { border-color: var(--accent); color: var(--accent); }

  .col-picker {
    max-height: 200px; overflow-y: auto;
    background: var(--surface3); border: 1px solid var(--border);
    border-radius: 6px; padding: 4px;
  }
  .col-item {
    display: flex; align-items: center; gap: 8px;
    padding: 5px 6px; border-radius: 5px; cursor: pointer;
    transition: background .1s;
  }
  .col-item:hover { background: var(--surface); }
  .col-item input[type=checkbox] { accent-color: var(--accent); cursor: pointer; flex-shrink: 0; }
  .col-item .col-name { font-family: var(--mono); font-size: 11px; color: var(--text); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .col-item .col-type-badge {
    margin-left: auto; font-family: var(--mono); font-size: 9px;
    padding: 1px 6px; border-radius: 100px; flex-shrink: 0;
    background: var(--surface2); color: var(--text-faint);
    border: 1px solid var(--border); cursor: default;
  }
  .col-type-badge.fre { color: var(--warn); border-color: #f59e0b44; }

  /* Coder filter */
  .coder-filter-toggle {
    display: flex; align-items: center; gap: 8px;
    font-size: 12px; color: var(--text-dim); cursor: pointer; user-select: none; margin-bottom: 10px;
  }
  .coder-filter-toggle input { accent-color: var(--accent); }
  .coder-multi { display: none; flex-direction: column; gap: 4px; }
  .coder-multi.visible { display: flex; }

  .run-btn {
    width: 100%; padding: 13px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border: none; border-radius: 8px; color: white;
    font-family: var(--sans); font-size: 14px; font-weight: 700;
    cursor: pointer; letter-spacing: .3px; transition: opacity .15s, transform .1s;
  }
  .run-btn:hover { opacity: .9; transform: translateY(-1px); }
  .run-btn:active { transform: translateY(0); }
  .run-btn:disabled { opacity: .4; cursor: not-allowed; transform: none; }

  .main-panel {
    overflow-y: auto; padding: 28px 32px;
    display: flex; flex-direction: column; gap: 24px;
  }

  .empty-state {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 16px;
    color: var(--text-faint); text-align: center; padding: 60px;
  }
  .empty-icon { font-size: 48px; opacity: .4; }
  .empty-state h2 { font-size: 18px; color: var(--text-dim); }
  .empty-state p { font-size: 13px; font-family: var(--mono); max-width: 360px; line-height: 1.6; }

  .results-header {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 12px;
  }
  .results-title { font-size: 20px; font-weight: 700; }
  .results-meta { font-family: var(--mono); font-size: 11px; color: var(--text-faint); }
  .export-btns { display: flex; gap: 8px; }
  .export-btn {
    padding: 7px 16px; border-radius: 6px; border: 1px solid var(--border-bright);
    background: var(--surface2); color: var(--text-dim);
    font-family: var(--mono); font-size: 11px; cursor: pointer; transition: all .15s;
  }
  .export-btn:hover { border-color: var(--accent); color: var(--accent); }

  .banner {
    padding: 12px 16px; border-radius: 8px; font-family: var(--mono); font-size: 12px;
    line-height: 1.6; display: flex; gap: 10px; align-items: flex-start;
  }
  .banner.error { background: rgba(248,113,113,.1); border: 1px solid #f8717133; color: var(--error); }
  .banner.warn  { background: rgba(245,158,11,.1);  border: 1px solid #f59e0b33; color: var(--warn); }
  .banner.info  { background: rgba(107,138,253,.1); border: 1px solid #6b8afd33; color: var(--accent); }
  .banner-icon { flex-shrink: 0; font-size: 14px; }

  .metric-block { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
  .metric-block-header {
    padding: 16px 20px; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 12px;
  }
  .metric-block-title { font-size: 15px; font-weight: 700; }
  .metric-block-sub { font-family: var(--mono); font-size: 11px; color: var(--text-faint); margin-left: auto; }

  .score-cell { background: var(--surface2); padding: 16px 18px; display: flex; flex-direction: column; gap: 4px; }
  .score-value { font-family: var(--mono); font-size: 26px; font-weight: 500; line-height: 1; }
  .score-value.good { color: var(--accent3); }
  .score-value.fair { color: var(--warn); }
  .score-value.poor { color: var(--error); }
  .score-value.na   { color: var(--text-faint); font-size: 16px; }
  .score-label { font-family: var(--mono); font-size: 10px; color: var(--text-faint); }
  .score-interp { font-size: 10px; color: var(--text-faint); margin-top: 2px; }

  .rq-table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-family: var(--mono); font-size: 11px; }
  thead tr { background: var(--surface3); }
  th {
    padding: 10px 14px; text-align: left; color: var(--text-faint);
    font-weight: 500; letter-spacing: .5px; white-space: nowrap; border-bottom: 1px solid var(--border);
  }
  td { padding: 9px 14px; border-bottom: 1px solid var(--border); color: var(--text); }
  tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: rgba(255,255,255,.02); }
  .val-good { color: var(--accent3); font-weight: 500; }
  .val-fair { color: var(--warn); }
  .val-poor { color: var(--error); }
  .val-na   { color: var(--text-faint); }

  .section-header {
    padding: 14px 20px; border-bottom: 1px solid var(--border);
    font-size: 12px; font-weight: 600; color: var(--text-dim);
    letter-spacing: .3px; display: flex; align-items: center; gap: 8px;
  }
  .section-header .pill {
    font-family: var(--mono); font-size: 10px; padding: 2px 8px; border-radius: 100px;
    background: var(--surface3); color: var(--text-faint); border: 1px solid var(--border);
  }

  .info-tooltip {
    display: inline-flex; align-items: center; justify-content: center;
    width: 14px; height: 14px; border-radius: 50%;
    background: var(--surface3); border: 1px solid var(--border-bright);
    color: var(--text-faint); font-size: 9px; font-family: var(--mono);
    cursor: help; margin-left: 6px; vertical-align: middle;
    position: relative; z-index: 10;
  }
  .info-tooltip:hover .tooltip-body {
    display: block;
  }
  .tooltip-body {
    display: none;
    position: fixed;
    width: 300px;
    background: var(--surface3);
    border: 1px solid var(--border-bright);
    border-radius: 8px;
    padding: 10px 12px;
    font-size: 10px;
    font-family: var(--mono);
    color: var(--text-dim);
    line-height: 1.6;
    z-index: 1000;
    pointer-events: none;
    white-space: normal;
    text-align: left;
    transform: translateX(-50%);
    margin-top: 8px;
  }


  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border-bright); border-radius: 3px; }

  .hidden { display: none !important; }

  .app-footer {
    border-top: 1px solid var(--border);
    background: var(--surface);
    padding: 10px 32px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    flex-shrink: 0;
  }
  .footer-credit {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-faint);
    line-height: 1.5;
  }
  .footer-credit strong { color: var(--text-dim); }
  .footer-divider {
    width: 1px; height: 24px;
    background: var(--border-bright);
    flex-shrink: 0;
  }
  .footer-experimental {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-faint);
    padding: 3px 10px;
    border-radius: 100px;
    border: 1px solid var(--border-bright);
    background: var(--surface2);
  }

  .preview-strip {
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 8px; padding: 10px 14px; font-family: var(--mono);
    font-size: 11px; color: var(--text-dim); line-height: 1.7;
  }
  .preview-strip strong { color: var(--accent3); }

  /* ── Summary side-by-side layout ── */
  .summary-body {
    display: flex;
    min-height: 0;
  }
  .summary-left {
    flex-shrink: 0;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
  }
  .summary-right {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }
  .summary-right-label {
    padding: 10px 16px 8px;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--text-faint);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .rq-cards-scroll {
    display: flex;
    flex-direction: row;
    overflow-x: auto;
    flex: 1;
    gap: 1px;
    background: var(--border);
  }
  .rq-cards-scroll::-webkit-scrollbar { height: 4px; }
  .rq-cards-scroll::-webkit-scrollbar-thumb { background: var(--border-bright); border-radius: 2px; }
  .score-cell-rq {
    background: var(--surface2);
    padding: 14px 18px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    min-width: 150px;
    flex-shrink: 0;
  }
  .score-rq-id {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-faint);
    margin-bottom: 2px;
    white-space: nowrap;
  }
  .score-metric-row { display: flex; align-items: baseline; gap: 6px; }
  .score-mini-val { font-family: var(--mono); font-size: 20px; font-weight: 500; line-height: 1; }
  .score-mini-val.good { color: var(--accent3); }
  .score-mini-val.fair { color: var(--warn); }
  .score-mini-val.poor { color: var(--error); }
  .score-mini-val.na   { color: var(--text-faint); font-size: 14px; }
  .score-mini-label { font-family: var(--mono); font-size: 9px; color: var(--text-faint); }
  .paper-index {
    display: inline-block;
    font-family: var(--mono); font-size: 9px;
    padding: 2px 8px; border-radius: 4px;
    background: var(--surface3); color: var(--text-dim);
    border: 1px solid var(--border);
    margin-left: 8px; vertical-align: middle;
    max-width: 320px;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }

  /* ── Two-level accordion: pair → paper → RQ ── */
  .pair-row { cursor: pointer; }
  .pair-row:hover td { background: rgba(107,138,253,.06) !important; }
  .pair-row td:first-child::before {
    content: '▶'; display: inline-block; font-size: 9px;
    margin-right: 8px; color: var(--text-faint); transition: transform .2s;
  }
  .pair-row.expanded td:first-child::before { transform: rotate(90deg); color: var(--accent); }

  .pair-expand-row { display: none; }
  .pair-expand-row.visible { display: table-row; }
  .pair-expand-cell { padding: 0 !important; border-bottom: 1px solid var(--border) !important; }

  .paper-sub-row { cursor: pointer; background: var(--surface2); }
  .paper-sub-row:hover td { background: rgba(107,138,253,.04) !important; }
  .paper-sub-row td:first-child::before {
    content: '▶'; display: inline-block; font-size: 8px;
    margin-right: 8px; color: var(--text-faint); transition: transform .2s;
  }
  .paper-sub-row.expanded td:first-child::before { transform: rotate(90deg); color: var(--accent2); }

  .rq-sub-row { display: none; background: var(--bg); }
  .rq-sub-row.visible { display: table-row; }
  .rq-sub-cell { padding: 0 !important; }
  .rq-sub-inner { background: var(--bg); border-top: 1px solid var(--border); }
  .rq-sub-inner td { padding: 7px 14px 7px 48px !important; font-size: 10px; border-bottom: 1px solid rgba(46,53,79,.4); }
  .rq-sub-inner tr:last-child td { border-bottom: none; }
  .rq-sub-inner tbody tr:hover td { background: rgba(255,255,255,.01); }
</style>
</head>
<body>

<header>
  <div class="logo-mark">IRR</div>
  <div>
    <h1>Inter-Rater Reliability Calculator</h1>
    <p>Learning Data Insights · GenAI Evidence Hub</p>
  </div>
  <div class="header-right"></div>
</header>

<div class="app-body">
  <aside class="sidebar">

    <!-- 01 Upload -->
    <div class="sidebar-section">
      <div class="section-label">01 — Upload File</div>
      <div class="drop-zone" id="dropZone">
        <input type="file" id="fileInput" accept=".csv,.xlsx,.xls,.tsv,.txt">
        <div class="drop-icon" id="dropIcon">📂</div>
        <div class="drop-text" id="dropText"><strong>Click or drag</strong> to upload coding sheet</div>
        <div class="drop-formats">.csv · .xlsx · .xls · .tsv · .txt</div>
      </div>
      <div id="filePreview" class="preview-strip hidden" style="margin-top:10px;"></div>
    </div>

    <!-- 02 Sheet Version -->
    <div class="sidebar-section" id="versionSection" style="display:none;">
      <div class="section-label">02 — Coding Sheet Version</div>
      <div class="version-cards">
        <div class="version-card" data-version="as" id="card-as">
          <div class="version-dot"></div>
          <div>
            <div class="version-name">Automated Scoring</div>
            <div class="version-sub">Auto-selects IRR columns</div>
          </div>
          <span class="version-badge">Active</span>
        </div>
        <div class="version-card" data-version="ig" id="card-ig">
          <div class="version-dot"></div>
          <div>
            <div class="version-name">Item Generation</div>
            <div class="version-sub">Auto-selects IRR columns</div>
          </div>
          <span class="version-badge">Active</span>
        </div>
        <div class="version-card disabled" data-version="ff" id="card-ff">
          <div class="version-dot"></div>
          <div>
            <div class="version-name">Formative Feedback</div>
            <div class="version-sub">Not yet available</div>
          </div>
          <span class="version-badge">Soon</span>
        </div>
      </div>
      <div class="detect-banner" id="detectBanner">
        <span>🔍</span>
        <span id="detectMsg"></span>
      </div>
    </div>

    <!-- 03 Configure Columns -->
    <div class="sidebar-section" id="colSection" style="display:none;">
      <div class="section-label">03 — Configure Columns</div>

      <div class="ctrl-row">
        <label class="ctrl-label">IRR columns
          <span style="color:var(--text-faint)"> — click ✓ to include/exclude</span>
        </label>
        <div class="col-picker-header">
          <span class="col-picker-count" id="pickerCount">0 selected</span>
          <div class="col-picker-actions">
            <button class="picker-action-btn" id="selectAllBtn">Select all</button>
            <button class="picker-action-btn" id="clearAllBtn">Clear</button>
          </div>
        </div>
        <div class="col-picker" id="colPicker"></div>
      </div>
    </div>

    <!-- 04 Coder Filter -->
    <div class="sidebar-section" id="coderSection" style="display:none;">
      <div class="section-label">04 — Coder Filter</div>
      <label class="coder-filter-toggle">
        <input type="checkbox" id="filterCoders"> Filter to specific coders only
      </label>
      <div class="coder-multi" id="coderMulti"></div>
    </div>

    <!-- 05 Run -->
    <div class="sidebar-section" id="runSection" style="display:none;">
      <button class="run-btn" id="runBtn">Calculate IRR</button>
    </div>

  </aside>

  <main class="main-panel" id="mainPanel">
    <div class="empty-state" id="emptyState">
      <div class="empty-icon">📊</div>
      <h2>No results yet</h2>
