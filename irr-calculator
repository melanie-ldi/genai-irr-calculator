let lastResults = null;
let activeVersion = null; // 'as' | 'ig' | 'ff' | null

// ═══════════════════════════════════════════
// FILE LOADING
// ═══════════════════════════════════════════
const dropZone = document.getElementById('dropZone');
const fileInput = document.getElementById('fileInput');

dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e => {
  e.preventDefault(); dropZone.classList.remove('drag-over'); handleFile(e.dataTransfer.files[0]);
});
fileInput.addEventListener('change', () => handleFile(fileInput.files[0]));

function handleFile(file) {
  if (!file) return;
  const ext = file.name.split('.').pop().toLowerCase();
  const reader = new FileReader();
  if (ext === 'xlsx' || ext === 'xls') {
    reader.onload = e => {
      const wb = XLSX.read(new Uint8Array(e.target.result), { type: 'array' });
      const ws = wb.Sheets[wb.SheetNames[0]];
      loadData(XLSX.utils.sheet_to_json(ws, { defval: '' }), file.name);
    };
    reader.readAsArrayBuffer(file);
  } else {
    reader.onload = e => {
      const text = e.target.result;
      const delim = ext === 'tsv' ? '\t' : detectDelim(text);
      const wb = XLSX.read(text, { type: 'string', FS: delim });
      const ws = wb.Sheets[wb.SheetNames[0]];
      loadData(XLSX.utils.sheet_to_json(ws, { defval: '' }), file.name);
    };
    reader.readAsText(file);
  }
}

function detectDelim(text) {
  const first = text.split('\n')[0];
  const t = (first.match(/\t/g)||[]).length;
  const c = (first.match(/,/g)||[]).length;
  const s = (first.match(/;/g)||[]).length;
  if (t >= c && t >= s) return '\t';
  if (s > c) return ';';
  return ',';
}

function loadData(data, filename) {
  rawData = data;
  allColumns = Object.keys(data[0] || {});
  colTypes = {};
  allColumns.forEach(c => { colTypes[c] = guessType(data, c); });

  dropZone.classList.add('file-loaded');
  document.getElementById('dropIcon').textContent = '✅';
  document.getElementById('dropText').innerHTML = `<strong>${filename}</strong>`;
  const prev = document.getElementById('filePreview');
  prev.classList.remove('hidden');
  prev.innerHTML = `<strong>${data.length}</strong> rows · <strong>${allColumns.length}</strong> columns detected`;

  // Auto-detect version
  const detected = detectVersion(allColumns);
  activeVersion = detected;

  document.getElementById('versionSection').style.display = '';
  renderVersionCards(detected);
  applyVersionAndRebuild(detected || 'as');

  document.getElementById('coderSection').style.display = '';
  document.getElementById('metricSection').style.display = '';
  document.getElementById('runSection').style.display = '';
}

function guessType(data, col) {
  const vals = data.map(r => r[col]).filter(v => v !== '' && v != null);
  const nums = vals.filter(v => !isNaN(Number(v)));
  if (nums.length > 0 && nums.length === vals.length) return 'interval';
  return 'nominal';
}

// ═══════════════════════════════════════════
// VERSION DETECTION & SELECTION
// ═══════════════════════════════════════════
function detectVersion(cols) {
  const colSet = new Set(cols);
  // Score each version by signature matches
  let best = null, bestScore = 0;
  for (const [key, def] of Object.entries(SHEET_VERSIONS)) {
    if (!def.signature.length) continue;
    const score = def.signature.filter(s => colSet.has(s)).length;
    if (score > bestScore) { bestScore = score; best = key; }
  }
  return best;
}

function renderVersionCards(detectedKey) {
  ['as','ig','ff'].forEach(k => {
    const card = document.getElementById(`card-${k}`);
    card.classList.remove('active');
    if (k !== 'ff') {
      card.onclick = () => {
        activeVersion = k;
        renderVersionCards(null);
        card.classList.add('active');
        applyVersionAndRebuild(k);
      };
    }
  });

  if (detectedKey && detectedKey !== 'ff') {
    document.getElementById(`card-${detectedKey}`).classList.add('active');
    const banner = document.getElementById('detectBanner');
    const msg = document.getElementById('detectMsg');
    banner.classList.add('visible');
    msg.textContent = `Auto-detected as "${SHEET_VERSIONS[detectedKey].name}" — verify or change above.`;
  } else if (!detectedKey) {
    document.getElementById('detectBanner').classList.remove('visible');
  }
}

function applyVersionAndRebuild(versionKey) {
  buildColumnSelectors(versionKey);
  document.getElementById('colSection').style.display = '';
}

