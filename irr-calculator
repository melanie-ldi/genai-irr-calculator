// ═══════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════
let rawData = [];
let allColumns = [];
let selectedCols = new Set();
let lastResults = null;
let activeVersion = null; // 'as' | 'ig' | 'ff' | null

// ═══════════════════════════════════════════
// FILE LOADING
// ═══════════════════════════════════════════
const dropZone = document.getElementById('dropZone');
const fileInput = document.getElementById('fileInput');

dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e => {
  e.preventDefault(); dropZone.classList.remove('drag-over'); handleFile(e.dataTransfer.files[0]);
});
fileInput.addEventListener('change', () => handleFile(fileInput.files[0]));

function handleFile(file) {
  if (!file) return;
  const ext = file.name.split('.').pop().toLowerCase();
  const reader = new FileReader();
  if (ext === 'xlsx' || ext === 'xls') {
    reader.onload = e => {
      const wb = XLSX.read(new Uint8Array(e.target.result), { type: 'array' });
      const ws = wb.Sheets[wb.SheetNames[0]];
      loadData(XLSX.utils.sheet_to_json(ws, { defval: '' }), file.name);
    };
    reader.readAsArrayBuffer(file);
  } else {
    reader.onload = e => {
      const text = e.target.result;
      const delim = ext === 'tsv' ? '\t' : detectDelim(text);
      const wb = XLSX.read(text, { type: 'string', FS: delim });
      const ws = wb.Sheets[wb.SheetNames[0]];
      loadData(XLSX.utils.sheet_to_json(ws, { defval: '' }), file.name);
    };
    reader.readAsText(file);
  }
}

function detectDelim(text) {
  const first = text.split('\n')[0];
  const t = (first.match(/\t/g)||[]).length;
  const c = (first.match(/,/g)||[]).length;
  const s = (first.match(/;/g)||[]).length;
  if (t >= c && t >= s) return '\t';
  if (s > c) return ';';
  return ',';
}

function loadData(data, filename) {
  rawData = data;
  allColumns = Object.keys(data[0] || {});

  dropZone.classList.add('file-loaded');
  document.getElementById('dropIcon').textContent = '✅';
  document.getElementById('dropText').innerHTML = `<strong>${filename}</strong>`;
  const prev = document.getElementById('filePreview');
  prev.classList.remove('hidden');
  prev.innerHTML = `<strong>${data.length}</strong> rows · <strong>${allColumns.length}</strong> columns detected`;

  // Auto-detect version
  const detected = detectVersion(allColumns);
  activeVersion = detected;

  document.getElementById('versionSection').style.display = '';
  renderVersionCards(detected);
  applyVersionAndRebuild(detected || 'as');

  document.getElementById('coderSection').style.display = '';
  document.getElementById('runSection').style.display = '';
}

// ═══════════════════════════════════════════
// VERSION DETECTION & SELECTION
// ═══════════════════════════════════════════

// Column names drift over time (renames, and stray leading/trailing spaces
// like "Domain " or "Metric1-min baseline " seen in real exports). Every
// comparison against a SHEET_VERSIONS column list goes through this
// normalizer so a header-only quirk doesn't silently fail to match.
function normColName(c) {
  return (c || '').trim().toLowerCase();
}

function detectVersion(cols) {
  const colSet = new Set(cols.map(normColName));
  // Score each version by signature matches
  let best = null, bestScore = 0;
  for (const [key, def] of Object.entries(SHEET_VERSIONS)) {
    if (!def.signature.length) continue;
    const score = def.signature.filter(s => colSet.has(normColName(s))).length;
    if (score > bestScore) { bestScore = score; best = key; }
  }
  return best;
}

function renderVersionCards(detectedKey) {
  ['as','ig','ff'].forEach(k => {
    const card = document.getElementById(`card-${k}`);
    card.classList.remove('active');
    if (k !== 'ff') {
      card.onclick = () => {
        activeVersion = k;
        renderVersionCards(null);
        card.classList.add('active');
        applyVersionAndRebuild(k);
      };
    }
  });

  if (detectedKey && detectedKey !== 'ff') {
    document.getElementById(`card-${detectedKey}`).classList.add('active');
    const banner = document.getElementById('detectBanner');
    const msg = document.getElementById('detectMsg');
    banner.classList.add('visible');
    msg.textContent = `Auto-detected as "${SHEET_VERSIONS[detectedKey].name}" — verify or change above.`;
  } else if (!detectedKey) {
    document.getElementById('detectBanner').classList.remove('visible');
  }
}

function applyVersionAndRebuild(versionKey) {
  buildColumnSelectors(versionKey);
  document.getElementById('colSection').style.display = '';
}

// ═══════════════════════════════════════════
// COLUMN SELECTORS
// ═══════════════════════════════════════════
const FIXED_PAPER_COL = 'Research Question ID';
const FIXED_CODER_COL = 'Reviewer';
const EXCLUDED_CODERS = new Set(['string']); // lowercase for case-insensitive match

function buildColumnSelectors(versionKey) {
  buildColPicker(versionKey);
  buildCoderList();

  document.getElementById('selectAllBtn').onclick = () => {
    document.querySelectorAll('.col-check').forEach(cb => {
      if (!cb.checked) { cb.checked = true; cb.dispatchEvent(new Event('change')); }
    });
  };
  document.getElementById('clearAllBtn').onclick = () => {
    document.querySelectorAll('.col-check').forEach(cb => {
      if (cb.checked) { cb.checked = false; cb.dispatchEvent(new Event('change')); }
    });
  };
}

function buildColPicker(versionKey) {
  const paperCol = FIXED_PAPER_COL;
  const coderCol = FIXED_CODER_COL;
  const exclude = new Set([paperCol, coderCol]);

  // Determine which cols to pre-select (whitespace/case-tolerant, see normColName)
  const versionCols = versionKey && SHEET_VERSIONS[versionKey]
    ? new Set(SHEET_VERSIONS[versionKey].cols.map(normColName)) : new Set();

  // Filter: only pre-check cols that are in the version definition AND present in the file
  // AND: for metric columns, only if at least one coder has a non-empty value
  const metricsWithData = versionKey ? getMetricColsWithData(versionKey, coderCol, paperCol) : new Set(allColumns);

  const picker = document.getElementById('colPicker');
  picker.innerHTML = '';
  selectedCols.clear();

  allColumns.filter(c => !exclude.has(c)).forEach(c => {
    const ft = isFreeText(c);
    const isMetricColFlag = /^Metric\d+-/.test(c);
    const shouldPreCheck = versionCols.has(normColName(c)) &&
      (!isMetricColFlag || metricsWithData.has(normColName(c))) &&
      !ft; // free-text fields shown but not pre-checked

    const wrap = document.createElement('div');

    const item = document.createElement('label');
    item.className = 'col-item';
    item.innerHTML = `
      <input type="checkbox" class="col-check" data-col="${esc(c)}" ${shouldPreCheck ? 'checked' : ''}>
      <span class="col-name" title="${esc(c)}">${c.length > 28 ? c.slice(0,26)+'…' : c}</span>
      ${ft ? `<span class="col-type-badge fre">⚠ free-text</span>` : ''}
    `;

    if (shouldPreCheck) selectedCols.add(c);

    item.querySelector('.col-check').addEventListener('change', function() {
      if (this.checked) selectedCols.add(c);
      else selectedCols.delete(c);
      updatePickerCount();
    });

    wrap.appendChild(item); picker.appendChild(wrap);
  });

  updatePickerCount();
}

// For metric columns: only include if at least one row has a non-empty value for that column
function getMetricColsWithData(versionKey, coderCol, paperCol) {
  const result = new Set();
  const vDef = SHEET_VERSIONS[versionKey];
  if (!vDef) return result;

  // Resolve each version-defined column name to whatever the real header
  // actually is (whitespace/case-tolerant), since real exports sometimes
  // have stray spaces (e.g. "Metric1-min baseline "). An exact-key lookup
  // against such a header would silently read undefined and mark a
  // genuinely populated column as empty.
  const realColByNorm = new Map();
  allColumns.forEach(c => realColByNorm.set(normColName(c), c));

  vDef.cols.forEach(col => {
    if (!/^Metric\d+-/.test(col)) {
      result.add(normColName(col)); // always include non-metric cols
      return;
    }
    const realCol = realColByNorm.get(normColName(col)) || col;
    // Check if any row has a non-empty value
    const hasData = rawData.some(row => {
      const v = row[realCol];
      return v !== undefined && v !== null && String(v).trim() !== '';
    });
    if (hasData) result.add(normColName(col));
  });

  return result;
}

function updatePickerCount() {
  document.getElementById('pickerCount').textContent = `${selectedCols.size} selected`;
}

function buildCoderList() {
  const coderMulti = document.getElementById('coderMulti');
  coderMulti.innerHTML = '';

  const coders = [...new Set(
    rawData
      .map(r => String(r[FIXED_CODER_COL] ?? '').trim())
      .filter(v => v && !EXCLUDED_CODERS.has(v.toLowerCase()))
  )];

  coders.forEach(coder => {
    const label = document.createElement('label');
    label.className = 'col-item';
    label.style.padding = '5px 6px';
    label.innerHTML = `<input type="checkbox" class="coder-check" value="${esc(coder)}" checked>
      <span class="col-name">${coder}</span>`;
    coderMulti.appendChild(label);
  });

  // remove stale listener then re-add
  const fc = document.getElementById('filterCoders');
  const newFc = fc.cloneNode(true);
  fc.parentNode.replaceChild(newFc, fc);
  newFc.addEventListener('change', function() {
    coderMulti.classList.toggle('visible', this.checked);
  });
}

function esc(s) { return String(s).replace(/"/g,'&quot;'); }

// ═══════════════════════════════════════════
// RUN
// ═══════════════════════════════════════════
document.getElementById('runBtn').addEventListener('click', () => {
  const paperCol = FIXED_PAPER_COL;
  const coderCol = FIXED_CODER_COL;
  const cols = [...selectedCols];

  const errors = [];
  if (cols.length === 0) errors.push('Please select at least one coding column.');
  if (errors.length) { showResults(null, errors); return; }

  // Build allowed coder set from filter
  let allowedCoders = null;
  const filterOn = document.getElementById('filterCoders').checked;
  if (filterOn) {
    allowedCoders = new Set([...document.querySelectorAll('.coder-check:checked')].map(el => el.value));
  }

  // Build flat records list — the canonical data structure for all IRR —
  // then realign metric slots by content (see realignMetricRecords) before
  // anything gets grouped or compared.
  const allRecords = realignMetricRecords(buildRecords(rawData, paperCol, coderCol, cols, allowedCoders));

  // Derive papers (RQ IDs) and coders from records
  const papers = [...new Set(allRecords.map(r => r.rq))].sort();
  const coders = [...new Set(allRecords.map(r => r.coder))].sort();

  // Detect free-text columns that are selected — warn user
  const freetextSelected = cols.filter(c => isFreeText(c));

  // ── Derive paper→RQ mapping and labels ──
  const PAPER_ID_COL = 'Paper ID';
  const PAPER_TITLE_COL = 'Paper Title';
  const RQ_TEXT_COL = 'Research Question';
  const paperNumToRQs = {};
  const paperGroupTitle = {};
  const paperGroupTitleFull = {};
  const rqLabelMap = {};
  const rqLabelFull = {};

  rawData.forEach(row => {
    const rqId = String(row[paperCol] ?? '').trim();
    if (!papers.includes(rqId)) return;
    const paperNum = row[PAPER_ID_COL] ? String(row[PAPER_ID_COL]).trim() : null;
    if (paperNum) {
      if (!paperNumToRQs[paperNum]) paperNumToRQs[paperNum] = new Set();
      paperNumToRQs[paperNum].add(rqId);
      if (!paperGroupTitleFull[paperNum]) {
        const t = row[PAPER_TITLE_COL] ? String(row[PAPER_TITLE_COL]).trim() : '';
        paperGroupTitleFull[paperNum] = t;
        paperGroupTitle[paperNum] = t.length > 50 ? t.slice(0,48)+'…' : t;
      }
    }
    if (!rqLabelFull[rqId]) {
      const rqText = row[RQ_TEXT_COL] ? String(row[RQ_TEXT_COL]).trim() : '';
      rqLabelFull[rqId] = rqText;
      rqLabelMap[rqId] = rqText.length > 52 ? rqText.slice(0,50)+'…' : rqText;
    }
  });

  const paperNums = Object.keys(paperNumToRQs).sort((a,b) => {
    const na=parseFloat(a), nb=parseFloat(b);
    return isNaN(na)||isNaN(nb) ? a.localeCompare(b) : na-nb;
  });

  // ── Build coder pairs ──
  const pairs = [];
  for (let i = 0; i < coders.length; i++)
    for (let j = i+1; j < coders.length; j++)
      pairs.push([coders[i], coders[j]]);
  const pk = (c1, c2) => `${c1} × ${c2}`;

  // Helper: does a pair share at least one (paper, rq, field) unit?
  function pairHasOverlap(c1, c2, records) {
    const c1units = new Set(records.filter(r=>r.coder===c1).map(r=>`${r.paper}\x00${r.rq}\x00${r.field}`));
    return records.some(r => r.coder===c2 && c1units.has(`${r.paper}\x00${r.rq}\x00${r.field}`));
  }

  // Only keep pairs where both coders have overlapping units
  const activePairs = pairs.filter(([c1,c2]) => pairHasOverlap(c1, c2, allRecords));

  // ── Pair-level alpha: pooled across ALL (Paper,RQ,Field) for that pair ──
  const pairResults = {};
  activePairs.forEach(([c1,c2]) => {
    const key = pk(c1,c2);
    const pr = allRecords.filter(r => r.coder===c1 || r.coder===c2);
    pairResults[key] = krippendorffAlpha(pr);
  });

  // ── Overall alpha: simple average of the per-pair alphas above ──
  // Deliberately NOT a single pooled calculation across all records — each
  // pair counts equally regardless of how many RQs it contributed, per how
  // this figure is actually used and reported.
  const pairAlphaValues = activePairs.map(([c1,c2]) => pairResults[pk(c1,c2)]).filter(v => v !== null);
  const overallAlpha = pairAlphaValues.length
    ? pairAlphaValues.reduce((a,b) => a+b, 0) / pairAlphaValues.length
    : null;

  // ── Pair × Paper alpha — only papers where both coders have overlapping units ──
  const pairPaperResults = {};
  activePairs.forEach(([c1,c2]) => {
    const key = pk(c1,c2);
    pairPaperResults[key] = {};
    paperNums.forEach(pNum => {
      const pr = allRecords.filter(r => r.paper===pNum && (r.coder===c1||r.coder===c2));
      // Only include if both coders have at least one overlapping unit on this paper
      const c1units = new Set(pr.filter(r=>r.coder===c1).map(r=>`${r.rq}\x00${r.field}`));
      const bothPresent = pr.some(r => r.coder===c2 && c1units.has(`${r.rq}\x00${r.field}`));
      if (bothPresent) pairPaperResults[key][pNum] = krippendorffAlpha(pr);
    });
  });

  // ── Pair × Paper × RQ alpha — only RQs where both coders have overlapping units ──
  const pairPaperRQResults = {};
  activePairs.forEach(([c1,c2]) => {
    const key = pk(c1,c2);
    pairPaperRQResults[key] = {};
    paperNums.forEach(pNum => {
      if (!pairPaperResults[key][pNum] && pairPaperResults[key][pNum] !== 0) return;
      pairPaperRQResults[key][pNum] = {};
      const rqList = [...(paperNumToRQs[pNum]||new Set())].sort();
      rqList.forEach(rqId => {
        const pr = allRecords.filter(r => r.paper===pNum && r.rq===rqId && (r.coder===c1||r.coder===c2));
        const c1units = new Set(pr.filter(r=>r.coder===c1).map(r=>r.field));
        const bothPresent = pr.some(r => r.coder===c2 && c1units.has(r.field));
        if (bothPresent) pairPaperRQResults[key][pNum][rqId] = krippendorffAlpha(pr);
      });
    });
  });

  lastResults = {
    overallAlpha, pairs: activePairs,
    pairResults,
    pairPaperResults,
    pairPaperRQResults,
    paperNums, paperNumToRQs, paperGroupTitle, paperGroupTitleFull,
    rqLabelMap, rqLabelFull,
    cols, papers, coders,
    allRecords, freetextSelected
  };
  showResults(lastResults, []);
});

// ═══════════════════════════════════════════
// VALUE NORMALIZATION
// ═══════════════════════════════════════════

// Free-text fields excluded from IRR (exact-string matching is unreliable)
const FREETEXT_FIELDS = new Set([
  'research question',
  'tested llm model & version used',
  'tested model & techniques list',
  'baseline list',
]);

// Per-metric free-text fields (Metric1-evaluation results, Metric2-Additional
// evaluation method notes, etc., for any metric number). Confirmed against
// Aaron's 6/18 coding sheet: his own "columns used for IRR" copy (A2:EU2 on
// the MB-CS tab) contains none of these for any metric slot — he excludes
// them entirely before calculating alpha, so the tool does too.
//
// min source / max source / min baseline / max baseline are also included:
// these hold a description of where a number came from (e.g. "KNN(all
// without subtopic)" vs. "KNN-all~T", or "Neuroticism subscale" vs.
// "neuroticism"), and Aaron's own designation rows repeatedly score these as
// agreement despite completely different wording — he's judging whether they
// refer to the same underlying thing, not comparing strings. That's a
// paraphrase judgment no exact-match tool can replicate, so these are
// excluded rather than let them manufacture disagreements Aaron never made.
// Note: this intentionally does NOT match "...baseline value",
// "...baseline difference", or "...baseline significant" — those hold the
// actual numbers/verdicts, not a description, and are compared normally.
const FREETEXT_METRIC_PATTERN = /^metric\d+-(evaluation results|additional evaluation method notes|min source|max source|min baseline|max baseline)$/i;

// Tokens treated as missing
const MISSING_TOKENS = new Set(['', 'n/a', 'na', 'none', '-', '--', 'n.a.', 'tbd', '?', '#value!', '#n/a', '#ref!', '#div/0!']);

// Sentinel for "this coder left the field blank." Confirmed against Aaron's
// actual 1/0 designation rows (not just the yellow highlighting) on the 6/18
// sheet: when one coder filled in a field and the other left it truly blank,
// every one of that field's cells is scored 1 vs 0 — a real disagreement, not
// excluded as missing data. Only when BOTH coders leave a field blank (e.g. a
// metric slot that simply doesn't apply to the paper) is the unit excluded —
// see the pruning step in groupIntoUnits below.
const MISSING_SENTINEL = '\x00MISSING\x00';

function isFreeText(colName) {
  const c = colName.trim().toLowerCase();
  return FREETEXT_FIELDS.has(c) || FREETEXT_METRIC_PATTERN.test(c);
}

function isNumericCol(colName) {
  // Heuristic: column name contains "number", "total", "count", "min", "max",
  // or ends with a number-like suffix
  return /\b(number|total|count|min|max|baseline value|baseline difference)\b/i.test(colName);
}

function isMultiselect(colName) {
  return /list$/i.test(colName) && !isFreeText(colName);
}

function normalizeValue(raw, colName) {
  if (raw === null || raw === undefined) return null;
  let s = String(raw).trim();
  if (MISSING_TOKENS.has(s.toLowerCase())) return null;

  // Numeric normalization: parse and normalize so "85" == "85.0"
  if (isNumericCol(colName)) {
    const isPct = s.endsWith('%');
    const stripped = s.replace(/%$/, '').replace(/,/g, '').trim();
    const n = parseFloat(stripped);
    if (!isNaN(n)) {
      const val = isPct ? n / 100 : n;
      const rounded = Math.round(val * 10000) / 10000;
      return rounded === Math.floor(rounded) ? String(Math.floor(rounded)) : String(rounded);
    }
  }

  // Multiselect: sort order-independently
  if (isMultiselect(colName) && s.includes(',')) {
    const parts = s.split(',').map(p => p.trim().toLowerCase()).filter(Boolean).sort();
    return parts.length ? parts.join('|') : null;
  }

  return s.toLowerCase();
}

// ═══════════════════════════════════════════
// RECORDS — flat list of (paper, rq, field, coder, value)
// This is the canonical data structure for all IRR calculations
// ═══════════════════════════════════════════
function buildRecords(rawData, paperCol, coderCol, cols, allowedCoders) {
  const PAPER_ID_COL = 'Paper ID';
  const ARTIFACT_ROW = 'numerical (index identifier)';

  const records = []; // {paper, rq, field, coder, value}

  rawData.forEach(row => {
    const rqId = String(row[paperCol] ?? '').trim();
    if (!rqId || /^\d+$/.test(rqId)) return; // bare integer artifacts
    if (rqId.toLowerCase() === ARTIFACT_ROW) return;

    const coder = String(row[coderCol] ?? '').trim();
    if (!coder || EXCLUDED_CODERS.has(coder.toLowerCase())) return;
    if (allowedCoders && !allowedCoders.has(coder)) return;

    // Paper ID for grouping
    const paperId = row[PAPER_ID_COL] !== undefined
      ? String(row[PAPER_ID_COL]).trim() : rqId;

    cols.forEach(col => {
      const raw = row[col];
      const value = normalizeValue(raw, col);
      records.push({ paper: paperId, rq: rqId, field: col, coder, value: value === null ? MISSING_SENTINEL : value });
    });
  });

  return records;
}

// ═══════════════════════════════════════════
// METRIC REALIGNMENT
// ═══════════════════════════════════════════
// Aaron realigns metrics by content before comparing them by hand — Chris's
// "Metric1" and Maggie's "Metric3" might describe the same underlying
// measurement, and the slot number is arbitrary. Comparing Metric1-to-Metric1
// by position (as this tool did before) creates false disagreements whenever
// two coders simply listed the same metrics in a different order. This step
// re-pairs each RQ's metrics across its two coders by content similarity
// before any field-level comparison happens, confirmed against real examples
// from the 6/18 sheet:
//   - A metric with no counterpart on the other side: every one of its
//     sub-fields counts as a disagreement, regardless of what's actually in
//     them — even a sub-field that's blank on the "found" side still
//     disagrees against the other coder's total absence.
//   - A metric matched to a counterpart: compared sub-field by sub-field,
//     with blank / N/A / #VALUE! all treated as one "nothing here" bucket —
//     bucket-vs-bucket is an agreement, bucket-vs-real-value is not.
//   - A metric slot neither coder used at all: excluded entirely, same as
//     before.
// Non-metric fields are untouched by this step.
const METRIC_FIELD_PATTERN = /^Metric(\d+)-(.+)$/;
const METRIC_IDENTITY_SUFFIXES = ['analysis type', 'category', 'type', 'assessment tool', 'truth'];
const NO_COUNTERPART = '\x00NO_COUNTERPART\x00';   // forced-mismatch marker for an unmatched metric
const BUCKET_MISSING = '\x00BUCKET_MISSING\x00';   // "nothing here" bucket, within a matched metric

function realignMetricRecords(records) {
  const metricRecords = [];
  const otherRecords = [];
  records.forEach(r => (METRIC_FIELD_PATTERN.test(r.field) ? metricRecords : otherRecords).push(r));
  if (!metricRecords.length) return records;

  // Group metric records by (paper, rq)
  const byUnit = new Map();
  metricRecords.forEach(r => {
    const key = `${r.paper}\x00${r.rq}`;
    if (!byUnit.has(key)) byUnit.set(key, []);
    byUnit.get(key).push(r);
  });

  const realigned = [];
  byUnit.forEach(recs => {
    const coders = [...new Set(recs.map(r => r.coder))];
    const { paper, rq } = recs[0];

    // Realignment only makes sense between exactly 2 coders. If this RQ has
    // some other number, leave its metric fields as plain per-slot records.
    if (coders.length !== 2) { realigned.push(...recs); return; }
    const [c1, c2] = coders;

    // metricNum -> suffix -> value, per coder
    const byCoderMetric = { [c1]: new Map(), [c2]: new Map() };
    recs.forEach(r => {
      const m = r.field.match(METRIC_FIELD_PATTERN);
      const num = m[1], suffix = m[2];
      const cm = byCoderMetric[r.coder];
      if (!cm.has(num)) cm.set(num, new Map());
      cm.get(num).set(suffix, r.value);
    });

    const usedMetrics = coder => [...byCoderMetric[coder].entries()]
      .filter(([, fields]) => [...fields.values()].some(v => v !== MISSING_SENTINEL))
      .map(([num]) => num);
    const nums1 = usedMetrics(c1);
    const nums2 = usedMetrics(c2);

    // Similarity score: count of identity fields that are equal AND both real
    // (non-blank). Blank fields never contribute — a match has to be earned
    // by shared real content, not by coincidental absence.
    function score(n1, n2) {
      const f1 = byCoderMetric[c1].get(n1), f2 = byCoderMetric[c2].get(n2);
      let s = 0;
      METRIC_IDENTITY_SUFFIXES.forEach(suf => {
        const v1 = f1.get(suf), v2 = f2.get(suf);
        if (v1 !== undefined && v2 !== undefined && v1 !== MISSING_SENTINEL && v2 !== MISSING_SENTINEL && v1 === v2) s++;
      });
      return s;
    }

    // Greedy max-weight bipartite matching — small n per RQ (usually ≤10
    // metrics/side), so greedy-by-descending-score is a fine approximation
    // of a true optimal assignment. Ties (including two metrics that share
    // zero identity-field overlap) prefer same slot number: if both coders
    // logged the same number of metrics but described them in completely
    // different terms, Aaron still compares them slot-for-slot rather than
    // calling them "unmatched" — confirmed against a real case where two
    // coders' single metric shared no identity-field agreement at all, yet
    // was scored as an ordinary (if total) mismatch, not a forced-absence
    // disagreement. "Unmatched" is reserved for genuine count imbalance —
    // a metric with literally no counterpart slot left on the other side —
    // not for weak or absent content overlap.
    const candidates = [];
    nums1.forEach(n1 => nums2.forEach(n2 => {
      candidates.push([n1, n2, score(n1, n2)]);
    }));
    candidates.sort((a, b) => (b[2] - a[2]) || ((a[0] === a[1] ? 0 : 1) - (b[0] === b[1] ? 0 : 1)));
    const matchedC1 = new Set(), matchedC2 = new Set(), matches = [];
    candidates.forEach(([n1, n2]) => {
      if (matchedC1.has(n1) || matchedC2.has(n2)) return;
      matchedC1.add(n1); matchedC2.add(n2);
      matches.push([n1, n2]);
    });

    let matchIdx = 0;

    // Matched metrics: compare sub-field by sub-field, blank/N/A/#VALUE!
    // collapsed into one equivalence bucket on both sides.
    matches.forEach(([n1, n2]) => {
      matchIdx++;
      const f1 = byCoderMetric[c1].get(n1), f2 = byCoderMetric[c2].get(n2);
      f1.forEach((v1, suf) => {
        const v2 = f2.get(suf);
        if (v2 === undefined) return; // suffix not in this dataset's column set
        const b1 = v1 === MISSING_SENTINEL ? BUCKET_MISSING : v1;
        const b2 = v2 === MISSING_SENTINEL ? BUCKET_MISSING : v2;
        const field = `MetricMatch${matchIdx}-${suf}`;
        realigned.push({ paper, rq, field, coder: c1, value: b1 });
        realigned.push({ paper, rq, field, coder: c2, value: b2 });
      });
    });

    // Unmatched metrics: every sub-field forced to disagree against the
    // other coder's total absence, regardless of its own content.
    nums1.filter(n => !matchedC1.has(n)).forEach(n1 => {
      matchIdx++;
      byCoderMetric[c1].get(n1).forEach((v1, suf) => {
        const field = `MetricMatch${matchIdx}-${suf}`;
        realigned.push({ paper, rq, field, coder: c1, value: v1 });
        realigned.push({ paper, rq, field, coder: c2, value: NO_COUNTERPART });
      });
    });
    nums2.filter(n => !matchedC2.has(n)).forEach(n2 => {
      matchIdx++;
      byCoderMetric[c2].get(n2).forEach((v2, suf) => {
        const field = `MetricMatch${matchIdx}-${suf}`;
        realigned.push({ paper, rq, field, coder: c1, value: NO_COUNTERPART });
        realigned.push({ paper, rq, field, coder: c2, value: v2 });
      });
    });

    // Metrics used by neither coder simply never appear in nums1/nums2 —
    // they produce no records at all, i.e. excluded from the calculation.
  });

  return [...otherRecords, ...realigned];
}

// ═══════════════════════════════════════════
// IRR MATH — pooled coincidence matrix
// ═══════════════════════════════════════════

// Group flat records into units keyed by (paper, rq, field) -> {coder: value}
function groupIntoUnits(records) {
  const units = new Map();
  records.forEach(({paper, rq, field, coder, value}) => {
    const key = `${paper}\x00${rq}\x00${field}`;
    if (!units.has(key)) units.set(key, {});
    units.get(key)[coder] = value;
  });

  // Percent-vs-decimal equivalence: for numeric fields, a value entered as a
  // percentage point by one coder and the same quantity as a decimal fraction
  // by the other (e.g. 3.89 vs. 0.0389) should compare as equal. Confirmed
  // against Aaron's own designation rows on the 6/18 sheet — he scores these
  // as agreement, not disagreement. Only applies within a single unit (two
  // coders describing the same thing), never across units.
  units.forEach((coderMap, key) => {
    const field = key.split('\x00')[2];
    if (!isNumericCol(field)) return;
    const entries = Object.entries(coderMap)
      .map(([coder, v]) => [coder, parseFloat(v)])
      .filter(([, n]) => !isNaN(n) && n !== 0);
    for (let i = 0; i < entries.length; i++) {
      for (let j = i + 1; j < entries.length; j++) {
        const [c1, n1] = entries[i], [c2, n2] = entries[j];
        if (coderMap[c1] === coderMap[c2]) continue; // already equal
        const ratio = n1 / n2;
        if (Math.abs(ratio - 100) < 0.5 || Math.abs(ratio - 0.01) < 0.00005) {
          coderMap[c2] = coderMap[c1]; // canonicalize to the same value
        }
      }
    }
  });

  // Drop units where every coder left the field blank — e.g. a metric slot
  // that simply doesn't apply to this paper. Nothing was coded by anyone, so
  // there's nothing to agree or disagree on. Units where at least one coder
  // filled it in are kept as-is (including any MISSING_SENTINEL entries),
  // so a blank-vs-filled split still counts as a disagreement.
  units.forEach((coderMap, key) => {
    if (Object.values(coderMap).every(v => v === MISSING_SENTINEL)) units.delete(key);
  });
  return units;
}

// Recode each unit's values into codes that are unique to that unit only —
// never reused by any other unit. Coders who agree within a unit still share
// a code; coders who disagree get distinct codes. This mirrors the recoding
// Aaron performs by hand before running his R script: it leaves the observed
// within-unit agreement/disagreement identical to the raw-value method, but
// prevents a literal answer that happens to repeat across many unrelated
// units (e.g. "Yes", or a common dropdown option) from being treated as one
// big shared category when estimating chance agreement. Validated against
// Aaron's manually-calculated alpha on the 6/18 dataset (see methodology note).
function recodeUnitsUniquely(units) {
  const recoded = new Map();
  let counter = 0;
  units.forEach((coderMap, key) => {
    const localMap = new Map(); // literal value -> unique code, local to this unit
    const newCoderMap = {};
    Object.entries(coderMap).forEach(([coder, value]) => {
      if (!localMap.has(value)) { counter++; localMap.set(value, counter); }
      newCoderMap[coder] = localMap.get(value);
    });
    recoded.set(key, newCoderMap);
  });
  return recoded;
}

// Core Krippendorff's alpha (nominal) computed from an already-grouped unit map
function alphaFromUnits(units) {
  // Build coincidence matrix
  const coinc = new Map(); // "va\x00vb" -> count
  const mu = new Map();    // value -> marginal count

  units.forEach(coderMap => {
    const vals = Object.values(coderMap);
    const m = vals.length;
    if (m < 2) return;
    const cnt = new Map();
    vals.forEach(v => cnt.set(v, (cnt.get(v) || 0) + 1));
    cnt.forEach((ca, a) => {
      cnt.forEach((cb, b) => {
        const pairs = a === b ? ca * (ca - 1) : ca * cb;
        const w = pairs / (m - 1);
        const key = `${a}\x00${b}`;
        coinc.set(key, (coinc.get(key) || 0) + w);
        mu.set(a, (mu.get(a) || 0) + w);
      });
    });
  });

  const n = [...mu.values()].reduce((s, v) => s + v, 0);
  if (n < 2) return null;

  const vals = [...mu.keys()];
  // Observed disagreement
  let Do = 0;
  vals.forEach(a => vals.forEach(b => {
    if (a !== b) Do += (coinc.get(`${a}\x00${b}`) || 0);
  }));
  Do /= n;

  // Expected disagreement
  let De = 0;
  vals.forEach(a => vals.forEach(b => {
    if (a !== b) De += mu.get(a) * mu.get(b);
  }));
  De /= (n * (n - 1));

  if (De === 0) return 1;
  return 1 - Do / De;
}

// Krippendorff's alpha via unique-per-unit recoding — matches Aaron's
// validated hand/R method. Before computing alpha, every (Paper, RQ, Field)
// unit is recoded so each unit gets codes unique to itself (matches share a
// code, mismatches get distinct codes, but no code is ever reused across
// units). This is necessary rather than pooling literal field values as
// categories, since a literal answer that happens to repeat across many
// unrelated units (e.g. "Yes", or a common dropdown option) would otherwise
// be treated as one shared category when estimating chance agreement.
// records: [{paper, rq, field, coder, value}]
// filterFn: optional fn(record) => bool to restrict scope
function krippendorffAlpha(records, filterFn) {
  const filtered = filterFn ? records.filter(filterFn) : records;
  return alphaFromUnits(recodeUnitsUniquely(groupIntoUnits(filtered)));
}

// ═══════════════════════════════════════════
// DISPLAY
// ═══════════════════════════════════════════
function fmtVal(v, isP) {
  if (v===null||v===undefined) return '<span class="val-na">—</span>';
  const n = isP ? v*100 : v;
  const cls = n>=(isP?80:0.8)?'val-good':n>=(isP?60:0.6)?'val-fair':'val-poor';
  return `<span class="${cls}">${n.toFixed(isP?1:3)}${isP?'%':''}</span>`;
}
function scoreClass(v) { return v===null?'na':v>=0.8?'good':v>=0.6?'fair':'poor'; }
function scoreInterp(v) {
  if (v===null) return 'N/A';
  return v>=0.8?'● Strong':v>=0.6?'◐ Moderate':'○ Low';
}

function showResults(res, errors) {
  const area = document.getElementById('resultsArea');
  document.getElementById('emptyState').classList.add('hidden');
  area.classList.remove('hidden');
  area.innerHTML = '';

  errors.forEach(e => area.innerHTML += banner('error','✖',e));
  if (!res) return;

  const {overallAlpha, pairs,
         pairResults,
         pairPaperResults,
         pairPaperRQResults,
         paperNums, paperNumToRQs, paperGroupTitle, paperGroupTitleFull,
         rqLabelMap, rqLabelFull,
         cols, papers, coders,
         allRecords, freetextSelected} = res;

  if (freetextSelected && freetextSelected.length > 0) {
    area.innerHTML += banner('warn','⚠',
      `<strong>${freetextSelected.length} free-text field${freetextSelected.length>1?'s':''} included:</strong> ${freetextSelected.join(', ')}. These use exact-string matching and may deflate IRR.`
    );
  }

  const vName = activeVersion ? SHEET_VERSIONS[activeVersion].name : '';
  const ts = new Date().toLocaleString();

  // ── Header ──
  const hdr = document.createElement('div');
  hdr.className = 'results-header';
  hdr.innerHTML = `
    <div>
      <div class="results-title">IRR Results <span class="info-tooltip">ℹ<span class="tooltip-body"><strong>Methodology note</strong><br>Krippendorff's α is computed by recoding every (Paper, RQ, Field) unit so each unit gets codes unique to itself (matches share a code, mismatches get distinct codes, but no code is ever reused across units) — this matches Aaron's validated hand/R method. Metric fields are realigned by content before comparison (not by slot position), a metric with no counterpart on the other side counts as a full disagreement, and blank/N/A/#VALUE! are treated as one equivalent "nothing here" bucket. <strong>Overall is the simple average of the per-pair α figures below</strong> — each coder pair counts equally, regardless of how many RQs it contributed. Numeric values are normalized (85 == 85.0), multiselect cells compared order-independently. Free-text fields may deflate alpha if included.</span></span></div>
      <div class="results-meta">${vName ? vName+' · ' : ''}${papers.length} RQs · ${cols.length} variables · ${coders.length} coders · ${ts}</div>
    </div>
    <div class="export-btns">
      <button class="export-btn" onclick="exportCSV()">⬇ Export CSV</button>
      <button class="export-btn" onclick="exportXLSX()">⬇ Export Excel</button>
    </div>`;
  area.appendChild(hdr);

  // ── 1. OVERALL SUMMARY ──
  const sb = document.createElement('div');
  sb.className = 'metric-block';

  let sh = `<div class="metric-block-header">
    <span class="metric-block-title">Overall Summary</span>
    <span class="metric-block-sub">All coders · ${pairs.length} pairs</span>
  </div><div class="summary-body">`;

  // Left: overall alpha
  const ov = overallAlpha;
  const ovDisp = ov !== null ? ov.toFixed(3) : '—';
  sh += `<div class="summary-left">
    <div class="score-cell" style="flex:1;">
      <span class="score-value ${scoreClass(ov)}">${ovDisp}</span>
      <span class="score-label">Krippendorff\'s α</span>
      <span class="score-interp">${scoreInterp(ov)}</span>
    </div>
  </div>`;

  // Right: by coder pair
  sh += `<div class="summary-right"><div class="summary-right-label">By Coder Pair</div><div class="rq-cards-scroll">`;
  pairs.forEach(([c1,c2]) => {
    const key = `${c1} × ${c2}`;
    const v = pairResults[key];
    const disp = v !== null ? v.toFixed(3) : '—';
    sh += `<div class="score-cell-rq">
      <div class="score-rq-id" style="font-size:11px;font-weight:700;color:var(--text);white-space:nowrap;">${key}</div>
      <div class="score-metric-row">
        <span class="score-mini-val ${scoreClass(v)}">${disp}</span>
        <span class="score-mini-label">Krippendorff\'s α</span>
      </div>
    </div>`;
  });
  sh += `</div></div></div>`;
  sb.innerHTML = sh;
  area.appendChild(sb);

  // ── 2. CODER PAIR IRR TABLE (two-level accordion) ──
  const tb = document.createElement('div');
  tb.className = 'metric-block';

  let th = `<div class="section-header">
    Coder Pair IRR
    <span class="pill">${pairs.length} pairs</span>
    <span class="pill" style="color:var(--accent);border-color:rgba(107,138,253,.3)">▶ click pair for paper detail · click paper for RQ detail</span>
  </div>
  <div class="rq-table-wrap"><table>
  <thead><tr><th>Coder Pair</th><th>Krippendorff\'s α</th></tr></thead><tbody>`;

  pairs.forEach(([c1,c2], pi) => {
    const key = `${c1} × ${c2}`;
    const v = pairResults[key];
    const pairRowId = `pair-expand-${pi}`;

    // Pair row
    th += `<tr class="pair-row" data-target="${pairRowId}">
      <td style="font-family:var(--mono);font-weight:600;">${key}</td>
      <td>${fmtVal(v, false)}</td>
    </tr>`;

    // Expandable paper sub-table
    let paperRows = '';
    const activePapersForPair = Object.keys(pairPaperResults[key]).sort((a,b) => {
      const na=parseFloat(a), nb=parseFloat(b);
      return isNaN(na)||isNaN(nb) ? a.localeCompare(b) : na-nb;
    });
    activePapersForPair.forEach((pNum, pni) => {
      const pv = pairPaperResults[key][pNum];
      const paperRowId = `paper-sub-${pi}-${pni}`;
      const title = paperGroupTitle[pNum] || '';

      // Paper sub-row
      paperRows += `<tr class="paper-sub-row" data-target="${paperRowId}">
        <td style="font-family:var(--mono);padding-left:24px;">
          Paper ${pNum}${title ? `<span class="paper-index" title="${paperGroupTitleFull[pNum]}">${title}</span>` : ''}
        </td>
        <td>${fmtVal(pv, false)}</td>
      </tr>`;

      // RQ sub-rows — only RQs where both coders overlapped
      const activeRQs = Object.keys(pairPaperRQResults[key][pNum]||{}).sort();
      let rqRows = '';
      activeRQs.forEach(rqId => {
        const rv = pairPaperRQResults[key][pNum][rqId];
        const label = rqLabelMap[rqId] || '';
        rqRows += `<tr>
          <td title="${rqLabelFull[rqId] || rqId}">${rqId}${label ? `<span class="paper-index">${label}</span>` : ''}</td>
          <td>${fmtVal(rv, false)}</td>
        </tr>`;
      });

      paperRows += `<tr class="rq-sub-row" id="${paperRowId}">
        <td class="rq-sub-cell" colspan="2">
          <div class="rq-sub-inner"><table><tbody>${rqRows}</tbody></table></div>
        </td>
      </tr>`;
    });

    th += `<tr class="pair-expand-row" id="${pairRowId}">
      <td class="pair-expand-cell" colspan="2">
        <div style="background:var(--surface2);">
          <table style="width:100%;border-collapse:collapse;font-family:var(--mono);font-size:11px;">
            <tbody>${paperRows}</tbody
>
          </table>
        </div>
      </td>
    </tr>`;
  });

  th += '</tbody></table></div>';
  tb.innerHTML = th;

  // Wire up pair accordion
  tb.querySelectorAll('.pair-row').forEach(row => {
    row.addEventListener('click', () => {
      const target = document.getElementById(row.dataset.target);
      const isOpen = target.classList.contains('visible');
      tb.querySelectorAll('.pair-expand-row.visible').forEach(r => r.classList.remove('visible'));
      tb.querySelectorAll('.pair-row.expanded').forEach(r => r.classList.remove('expanded'));
      if (!isOpen) { target.classList.add('visible'); row.classList.add('expanded'); }
    });
  });

  // Wire up paper sub-accordion (using event delegation on the table)
  tb.addEventListener('click', e => {
    const paperRow = e.target.closest('.paper-sub-row');
    if (!paperRow) return;
    e.stopPropagation();
    const targetId = paperRow.dataset.target;
    const target = document.getElementById(targetId);
    if (!target) return;
    const isOpen = target.classList.contains('visible');
    // Close siblings in same pair expand block
    const pairExpand = paperRow.closest('.pair-expand-row');
    if (pairExpand) {
      pairExpand.querySelectorAll('.rq-sub-row.visible').forEach(r => r.classList.remove('visible'));
      pairExpand.querySelectorAll('.paper-sub-row.expanded').forEach(r => r.classList.remove('expanded'));
    }
    if (!isOpen) { target.classList.add('visible'); paperRow.classList.add('expanded'); }
  });

  area.appendChild(tb);
}

function banner(type,icon,msg) {
  return `<div class="banner ${type}"><span class="banner-icon">${icon}</span><span>${msg}</span></div>`;
}

// ═══════════════════════════════════════════
// EXPORT
// ═══════════════════════════════════════════
function exportCSV() {
  if (!lastResults) return;
  const {overallAlpha, pairs,
         pairResults,
         pairPaperResults,
         pairPaperRQResults,
         paperNums, paperNumToRQs, paperGroupTitleFull, rqLabelFull} = lastResults;
  const pk = (c1,c2) => `${c1} × ${c2}`;
  const fmt = v => v !== null ? v.toFixed(4) : 'N/A';

  const lines = [];
  lines.push(['OVERALL SUMMARY', "Krippendorff's α"].join(','));
  lines.push(['Overall IRR', fmt(overallAlpha)].join(','));
  lines.push('');

  lines.push(['BY CODER PAIR', "Krippendorff's α"].join(','));
  pairs.forEach(([c1,c2]) => {
    const key = pk(c1,c2);
    lines.push([key, fmt(pairResults[key])].join(','));
  });
  lines.push('');

  lines.push(['CODER PAIR DETAIL', 'Paper / RQ', "Krippendorff's α"].join(','));
  pairs.forEach(([c1,c2]) => {
    const key = pk(c1,c2);
    lines.push([key, '', fmt(pairResults[key])].join(','));
    const activePapers = Object.keys(pairPaperResults[key]).sort((a,b)=>{const na=parseFloat(a),nb=parseFloat(b);return isNaN(na)||isNaN(nb)?a.localeCompare(b):na-nb;});
    activePapers.forEach(pNum => {
      const title = paperGroupTitleFull[pNum] || '';
      lines.push(['', JSON.stringify(`Paper ${pNum} — ${title}`), fmt(pairPaperResults[key][pNum])].join(','));
      const activeRQs = Object.keys(pairPaperRQResults[key][pNum]||{}).sort();
      activeRQs.forEach(rqId => {
        const rqText = rqLabelFull[rqId] || rqId;
        lines.push(['', JSON.stringify(`  ${rqId}: ${rqText}`), fmt(pairPaperRQResults[key][pNum][rqId])].join(','));
      });
    });
    lines.push('');
  });

  dlBlob(new Blob([lines.join('\n')],{type:'text/csv'}), 'irr_results.csv');
}

function exportXLSX() {
  if (!lastResults) return;
  const {overallAlpha, pairs,
         pairResults,
         pairPaperResults,
         pairPaperRQResults,
         paperNums, paperNumToRQs, paperGroupTitleFull, rqLabelFull} = lastResults;
  const pk = (c1,c2) => `${c1} × ${c2}`;
  const fmt = v => v !== null ? parseFloat(v.toFixed(4)) : 'N/A';

  const wb = XLSX.utils.book_new();
  const wsData = [];

  // ── OVERALL ──
  wsData.push(['OVERALL SUMMARY', "Krippendorff's α"]);
  wsData.push(['Overall IRR', fmt(overallAlpha)]);
  wsData.push([]);

  // ── BY CODER PAIR summary ──
  wsData.push(['BY CODER PAIR', "Krippendorff's α"]);
  pairs.forEach(([c1,c2]) => {
    const key = pk(c1,c2);
    wsData.push([key, fmt(pairResults[key])]);
  });
  wsData.push([]);

  // ── DETAIL: pair > paper > RQ ──
  wsData.push(['CODER PAIR DETAIL', 'Paper / RQ', "Krippendorff's α"]);
  pairs.forEach(([c1,c2]) => {
    const key = pk(c1,c2);
    wsData.push([key, '', fmt(pairResults[key])]);
    const activePapers = Object.keys(pairPaperResults[key]).sort((a,b)=>{const na=parseFloat(a),nb=parseFloat(b);return isNaN(na)||isNaN(nb)?a.localeCompare(b):na-nb;});
    activePapers.forEach(pNum => {
      const title = paperGroupTitleFull[pNum] || '';
      wsData.push(['', `Paper ${pNum} — ${title}`, fmt(pairPaperResults[key][pNum])]);
      const activeRQs = Object.keys(pairPaperRQResults[key][pNum]||{}).sort();
      activeRQs.forEach(rqId => {
        const rqText = rqLabelFull[rqId] || rqId;
        wsData.push(['', `  ${rqId}: ${rqText}`, fmt(pairPaperRQResults[key][pNum][rqId])]);
      });
    });
    wsData.push([]);
  });

  const ws = XLSX.utils.aoa_to_sheet(wsData);
  ws['!cols'] = [{ wch: 28 }, { wch: 60 }, { wch: 16 }];

  const range = XLSX.utils.decode_range(ws['!ref']);
  for (let R = range.s.r; R <= range.e.r; R++) {
    for (let C = range.s.c; C <= range.e.c; C++) {
      const addr = XLSX.utils.encode_cell({r:R, c:C});
      if (!ws[addr]) continue;
      const cell = ws[addr];
      const val = cell.v;
      // Detect row type
      const isHeader = val === 'OVERALL SUMMARY' || val === 'BY CODER PAIR' || val === 'CODER PAIR DETAIL';
      const isOverallData = R === 1;
      const isPairSummary = R >= 4 && R < 4 + pairs.length;
      const isPairHeader = typeof val === 'string' && pairs.some(([c1,c2]) => val === `${c1} × ${c2}`) && C === 0;
      cell.s = {
        font: { name: 'Calibri', sz: isHeader ? 11 : 10,
          bold: isHeader || isPairHeader || isOverallData,
          color: { rgb: isHeader ? 'FFFFFF' : '1A1A2E' }
        },
        fill: { patternType: 'solid', fgColor: { rgb:
          isHeader ? '4A5FA8' : isPairHeader ? '2E3550' :
          isOverallData ? 'E8ECF8' : 'FFFFFF'
        }},
        alignment: { horizontal: C === 2 ? 'center' : 'left', vertical: 'center', wrapText: C === 1 },
        border: { bottom: { style: 'thin', color: { rgb: 'C5CAD8' }}, right: { style: 'thin', color: { rgb: 'C5CAD8' }}}
      };
      // Color-code alpha values
      if (C === 2 && cell.t === 'n') {
        const color = val >= 0.8 ? '1A7A4A' : val >= 0.6 ? 'B45309' : 'B91C1C';
        cell.s.font.color = { rgb: color };
        cell.s.font.bold = true;
      }
    }
  }

  XLSX.utils.book_append_sheet(wb, ws, 'IRR Results');
  XLSX.writeFile(wb, 'irr_results.xlsx');
}


function dlBlob(blob, name) {
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href=url; a.download=name; a.click(); URL.revokeObjectURL(url);
}

// ── Tooltip positioning ──
document.addEventListener('mouseover', e => {
  const tip = e.target.closest('.info-tooltip');
  if (!tip) return;
  const body = tip.querySelector('.tooltip-body');
  if (!body) return;
  const rect = tip.getBoundingClientRect();
  const left = Math.max(10, Math.min(rect.left + rect.width/2, window.innerWidth - 160));
  body.style.left = left + 'px';
  body.style.top = (rect.bottom + 8) + 'px';
});
