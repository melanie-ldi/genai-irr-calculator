// ═══════════════════════════════════════════
// RUN
// ═══════════════════════════════════════════
document.getElementById('runBtn').addEventListener('click', () => {
  const paperCol = FIXED_PAPER_COL;
  const coderCol = FIXED_CODER_COL;
  const cols = [...selectedCols];
  const metrics = getSelectedMetrics();

  const errors = [];
  if (cols.length === 0) errors.push('Please select at least one coding column.');
  if (metrics.length === 0) errors.push('Please select at least one metric.');
  if (errors.length) { showResults(null, errors, []); return; }

  // Build allowed coder set from filter
  let allowedCoders = null;
  const filterOn = document.getElementById('filterCoders').checked;
  if (filterOn) {
    allowedCoders = new Set([...document.querySelectorAll('.coder-check:checked')].map(el => el.value));
  }

  // Build flat records list — the canonical data structure for all IRR
  const allRecords = buildRecords(rawData, paperCol, coderCol, cols, allowedCoders);

  // Derive papers (RQ IDs) and coders from records
  const papers = [...new Set(allRecords.map(r => r.rq))].sort();
  const coders = [...new Set(allRecords.map(r => r.coder))].sort();
  const nCoders = coders.length;

  // Detect free-text columns that are selected — warn user
  const freetextSelected = cols.filter(c => isFreeText(c));

  const metricErrors = {}, metricWarnings = {};
  metrics.forEach(m => {
    metricErrors[m] = []; metricWarnings[m] = [];
    if (m === 'cohen' && nCoders !== 2)
      metricErrors[m].push(`Cohen's Kappa requires exactly 2 coders. Found ${nCoders}: ${coders.join(', ')}.`);
    if (m === 'fleiss' && nCoders < 3)
      metricErrors[m].push(`Fleiss' Kappa requires 3+ coders. Found ${nCoders}.`);
    if (m === 'pairwise') {
      const nP = (nCoders*(nCoders-1))/2;
      if (nP > 45) metricWarnings[m].push(`${nCoders} coders → ${nP} pairs. Displaying aggregated results.`);
    }
  });

  // ── Derive paper→RQ mapping and labels ──
  const PAPER_ID_COL = 'Paper ID';
  const PAPER_TITLE_COL = 'Paper Title';
  const RQ_TEXT_COL = 'Research Question';
  const paperNumToRQs = {};
  const paperGroupTitle = {};
  const paperGroupTitleFull = {};
  const rqLabelMap = {};
  const rqLabelFull = {};

  rawData.forEach(row => {
    const rqId = String(row[paperCol] ?? '').trim();
    if (!papers.includes(rqId)) return;
    const paperNum = row[PAPER_ID_COL] ? String(row[PAPER_ID_COL]).trim() : null;
    if (paperNum) {
      if (!paperNumToRQs[paperNum]) paperNumToRQs[paperNum] = new Set();
      paperNumToRQs[paperNum].add(rqId);
      if (!paperGroupTitleFull[paperNum]) {
        const t = row[PAPER_TITLE_COL] ? String(row[PAPER_TITLE_COL]).trim() : '';
        paperGroupTitleFull[paperNum] = t;
        paperGroupTitle[paperNum] = t.length > 50 ? t.slice(0,48)+'…' : t;
      }
    }
    if (!rqLabelFull[rqId]) {
      const rqText = row[RQ_TEXT_COL] ? String(row[RQ_TEXT_COL]).trim() : '';
      rqLabelFull[rqId] = rqText;
      rqLabelMap[rqId] = rqText.length > 52 ? rqText.slice(0,50)+'…' : rqText;
    }
  });

  const paperNums = Object.keys(paperNumToRQs).sort((a,b) => {
    const na=parseFloat(a), nb=parseFloat(b);
    return isNaN(na)||isNaN(nb) ? a.localeCompare(b) : na-nb;
  });

  // ── Build coder pairs ──
  const pairs = [];
  for (let i = 0; i < coders.length; i++)
    for (let j = i+1; j < coders.length; j++)
      pairs.push([coders[i], coders[j]]);
  const pk = (c1, c2) => `${c1} × ${c2}`;

  // ── Overall alpha (all coders) for left summary card ──
  const overallAlpha = (!metricErrors['alpha'] || !metricErrors['alpha'].length)
    ? krippendorffAlphaPooled(allRecords) : null;

  // Helper: does a pair share at least one (paper, rq, field) unit?
  function pairHasOverlap(c1, c2, records) {
    const c1units = new Set(records.filter(r=>r.coder===c1).map(r=>`${r.paper}\x00${r.rq}\x00${r.field}`));
    return records.some(r => r.coder===c2 && c1units.has(`${r.paper}\x00${r.rq}\x00${r.field}`));
  }

  // Only keep pairs where both coders have overlapping units
  const activePairs = pairs.filter(([c1,c2]) => pairHasOverlap(c1, c2, allRecords));

  // ── Pair-level alpha: pooled across ALL (Paper,RQ,Field) for that pair ──
  const pairResults = {};
  activePairs.forEach(([c1,c2]) => {
    const key = pk(c1,c2);
    const pr = allRecords.filter(r => r.coder===c1 || r.coder===c2);
    pairResults[key] = krippendorffAlphaPooled(pr);
  });

  // ── Pair × Paper alpha — only papers where both coders have overlapping units ──
  const pairPaperResults = {};
  activePairs.forEach(([c1,c2]) => {
    const key = pk(c1,c2);
    pairPaperResults[key] = {};
    paperNums.forEach(pNum => {
      const pr = allRecords.filter(r => r.paper===pNum && (r.coder===c1||r.coder===c2));
      // Only include if both coders have at least one overlapping unit on this paper
      const c1units = new Set(pr.filter(r=>r.coder===c1).map(r=>`${r.rq}\x00${r.field}`));
      const bothPresent = pr.some(r => r.coder===c2 && c1units.has(`${r.rq}\x00${r.field}`));
      if (bothPresent) pairPaperResults[key][pNum] = krippendorffAlphaPooled(pr);
    });
  });

  // ── Pair × Paper × RQ alpha — only RQs where both coders have overlapping units ──
  const pairPaperRQResults = {};
  activePairs.forEach(([c1,c2]) => {
    const key = pk(c1,c2);
    pairPaperRQResults[key] = {};
    paperNums.forEach(pNum => {
      if (!pairPaperResults[key][pNum] && pairPaperResults[key][pNum] !== 0) return;
      pairPaperRQResults[key][pNum] = {};
      const rqList = [...(paperNumToRQs[pNum]||new Set())].sort();
      rqList.forEach(rqId => {
        const pr = allRecords.filter(r => r.paper===pNum && r.rq===rqId && (r.coder===c1||r.coder===c2));
        const c1units = new Set(pr.filter(r=>r.coder===c1).map(r=>r.field));
        const bothPresent = pr.some(r => r.coder===c2 && c1units.has(r.field));
        if (bothPresent) pairPaperRQResults[key][pNum][rqId] = krippendorffAlphaPooled(pr);
      });
    });
  });

  lastResults = {
    overallAlpha, pairs: activePairs, pairResults, pairPaperResults, pairPaperRQResults,
    paperNums, paperNumToRQs, paperGroupTitle, paperGroupTitleFull,
    rqLabelMap, rqLabelFull,
    cols, papers, coders, metrics, metricErrors, metricWarnings,
    allRecords, freetextSelected
  };
  showResults(lastResults, [], []);
});

